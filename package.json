{
  "name": "passwordepic",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "start": "expo start --dev-client",
    "start:metro": "react-native start",
    "test": "jest",
    "tsc": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace PasswordEpic.xcworkspace -scheme PasswordEpic -configuration Release -destination generic/platform=iOS -archivePath PasswordEpic.xcarchive archive",
    "build:dev:android": "eas build --platform android --profile development",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:production:android": "eas build --platform android --profile production",
    "build:production:ios": "eas build --platform ios --profile production",
    "clean": "react-native clean-project-auto",
    "reset-cache": "react-native start --reset-cache",
    "postinstall": "echo 'Install complete'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "^5.0.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@reduxjs/toolkit": "^2.3.0",
    "expo": "~54.0.9",
    "expo-build-properties": "~1.0.9",
    "expo-dev-client": "~6.0.12",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-biometrics": "^3.0.1",
    "react-native-get-random-values": "^1.11.0",
    "react-native-keychain": "^8.1.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/cli": "^12.0.0",
    "@react-native-community/cli-platform-android": "^20.0.2",
    "@react-native/eslint-config": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "^2.4.1",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
